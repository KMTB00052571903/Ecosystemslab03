{
  "version": 2,
  "builds": [
    {
      "src": "**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/",
      "dest": "/index.html"
    },
    {
      "src": "/consumer(/.*)?",
      "dest": "/consumer/index.html"
    },
    {
      "src": "/delivery(/.*)?",
      "dest": "/delivery/index.html"
    },
    {
      "src": "/store(/.*)?",
      "dest": "/store/index.html"
    }
  ]
}